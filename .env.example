# ============================================================
# ELECTRA — Election Process Education Assistant
# Environment Variables Configuration
# ============================================================
# IMPORTANT: NEVER commit your actual .env file to GitHub.
# If you are submitting this for the hackathon, ensure .env is 
# in your .gitignore file (which we have already set up for you).
# ============================================================

# ─── 1. GOOGLE GEMINI API KEY ───────────────────────────────
# What it does: Powers the core AI chat generation, vision, and logic.
# Where to get it: 
#   1. Go to https://aistudio.google.com/
#   2. Sign in with your Google account.
#   3. Click "Get API key" on the left menu.
#   4. Click "Create API key in new project".
# Where to paste it: Replace the text below with your actual key (it usually starts with AIza...)
GOOGLE_API_KEY=your_google_api_key_here

# ─── 2. PRIMARY MODELS SELECTION ────────────────────────────
# Because this is a Google-organized hackathon, we are exclusively 
# utilizing the highest-tier Gemini models for maximum capability.
MODEL_CHAT=gemini-2.5-pro
MODEL_VISION=gemini-2.5-pro
MODEL_FAST=gemini-2.5-flash

# ─── 3. APP CONFIGURATION ───────────────────────────────────
# You do not need to change these.
APP_NAME=ELECTRA
APP_VERSION=2.0.0
NODE_ENV=development
